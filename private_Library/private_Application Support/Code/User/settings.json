        {
            "backgroundColor": "#FF9900",
            "color": "#fff",
            "text": "DEBUG"
        },
        {
            "backgroundColor": "#235BC8",
            "color": "#fff",
            "text": "MEMO"
        }
    ],
    "turboConsoleLog.delimiterInsideMessage": "=>",
    "turboConsoleLog.insertEmptyLineAfterLogMessage": true,
    "window.commandCenter": true,
    "window.zoomLevel": 2,
    "workbench.activityBar.location": "top",
    "workbench.browser.enableChatTools": true,
    "workbench.colorCustomizations": {
        "contrastActiveBorder": "#0493e6",
        "editorGroup.border": "#1481c0",
        "editorStickyScroll.background": "#332765",
        "editorStickyScrollHover.background": "#504083",
        "tab.activeBackground": "#7f0daf",
        "tab.unfocusedActiveBackground": "#350d46",
        "titleBar.border": "#ea11c6"
    },
    "workbench.colorTheme": "Dark Modern",
    "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "maximize",
    "workbench.editor.openPositioning": "last",
    "workbench.editor.splitInGroupLayout": "vertical",
    "workbench.editor.tabSizing": "shrink",
    "xml.format.legacy": true
}
