    "css.validate": false,
    "csv.enabled": false,
    "debug.console.wordWrap": false,
    "dev.containers.copyGitConfig": false, // ホストの Git 設定をコンテナにコピーしない（dotfiles repo から取得するため不要）
    "dev.containers.defaultExtensions": [
        "GitHub.copilot", // GitHub Copilot (コード補完)
        "GitHub.copilot-chat", // GitHub Copilot Chat
        "GitHub.vscode-pull-request-github", // GitHub Pull Requests and Issues (GitHub 連携)
        "oxc.oxc-vscode", // Oxc (コードフォーマッタとリンター)
        "formulahendry.auto-rename-tag", // Auto Rename Tag (HTML タグの自動ペア編集)
        "wmaurer.change-case", // Change Case (選択範囲の文字列の大文字・小文字変換)
        "streetsidesoftware.code-spell-checker", // Code Spell Checker (スペルチェック)
        "nemesv.copy-file-name", // Copy File Name (ファイル名のコピー)
        "mhutchie.git-graph", // Git Graph (Git 履歴の可視化)
        "eamodio.gitlens", // GitLens (Git 履歴の強化)
        "ms-ceintl.vscode-language-pack-ja", // Japanese Language Pack for Visual Studio Code (日本語化)
        "shd101wyy.markdown-preview-enhanced", // Markdown Preview Enhanced (Markdown プレビューの強化)
        "davidanson.vscode-markdownlint", // markdownlint (Markdown の静的解析)
        "christian-kohler.path-intellisense", // Path Intellisense (ファイルパスの補完)
        "yoavbls.pretty-ts-errors", // Pretty TypeScript Errors (TypeScript エラーの見やすい表示)
        "stylelint.vscode-stylelint", // Stylelint (CSS の静的解析)
        "wayou.vscode-todo-highlight", // todo Highlight (todo コメントの強調表示)
        "shardulm94.trailing-spaces" // Trailing Spaces (行末の不要なスペースの強調表示)
    ],
    "diffEditor.codeLens": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.maxComputationTime": 0,
    "diffEditor.renderSideBySideInlineBreakpoint": 1,
    "dotfiles.repository": "melumuccu/dotfiles",
    "editor.acceptSuggestionOnEnter": "on",
    "editor.accessibilitySupport": "off",
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "always",
        "source.fixAll.sortJSON": "explicit",
        "source.fixAll.stylelint": "explicit",
        "source.format.oxc": "always",
        "source.sort.json": "explicit"
    },
    "editor.copyWithSyntaxHighlighting": false,
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.dragAndDrop": false,
    "editor.fontSize": 15,
    "editor.formatOnSave": false, // oxc で先にフォーマットする設定のために disable にする (editor.codeActionsOnSave で設定)
    "editor.formatOnSaveMode": "file",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.guides.bracketPairs": true,
    "editor.inlineSuggest.enabled": true,
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.pasteAs.preferences": [
        "text.updateImports"
    ],
    "editor.renderControlCharacters": true,
    "editor.renderLineHighlight": "all",
    "editor.snippetSuggestions": "top",
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 10,
    "editor.suggest.preview": true,
    "editor.suggest.showMethods": true,
    "editor.suggestSelection": "first",
    "editor.tabSize": 2,
    "editor.trimAutoWhitespace": true,
    "editor.unusualLineTerminators": "auto",
    "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",
    "emmet.includeLanguages": {
        "astro": "html",
        "erb": "html"
    },
    "emmet.triggerExpansionOnTab": true,
    "eslint.validate": [
        "typescript",
        "typescriptreact"
    ],
    "explorer.autoReveal": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "explorer.fileNesting.patterns": {
        "*.module.css": "*.module.css.d.ts, *.module.css.d.ts.map"
    },
    "explorer.openEditors.visible": 1,
    "extensions.ignoreRecommendations": true,
    "figma.assetExportDirectory": "src/assets/icon",
    "figma.assetPublicPath": "",
    "figma.autocompleteBlocks": true,
    "figma.autocompleteProperties": false,
    "files.associations": {
        ".clinerules": "markdown",
        "*.astro": "astro",
        "*.html.erb": "erb",
        "*.tmpl": "go",
        "*.toml": "ini"
    },
    "files.exclude": {
        "**/.git": false
    },
    "files.insertFinalNewline": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "never",
    "git.suggestSmartCommit": false,
    "github.copilot.enable": {
        "*": true,
        "astro": true,
        "css": true,
        "markdown": true,
        "plaintext": false,
        "scminput": false,
        "scss": true,
        "yaml": true
    },
    "github.copilot.nextEditSuggestions.enabled": true, // preview: NES
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.scopes": [],
    "gitlens.views.commits.files.layout": "list",
    "gitlens.views.commits.pullRequests.enabled": false,
    "gitlens.views.commits.pullRequests.showForBranches": false,
    "gitlens.views.commits.showBranchComparison": false,
    "gitlens.views.showRelativeDateMarkers": false,
    "html.format.enable": false,
    "http.systemCertificatesNode": true,
    "js/ts.suggest.completeFunctionCalls": true,
    "js/ts.suggest.paths": false,
    "js/ts.tsserver.tracing.enabled": true,
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "json.schemas": [],
    "launch": {
        "compounds": [],
        "configurations": []
    },
    "markdown-pdf.outputDirectory": "output",
    "markdown-pdf.outputDirectoryRelativePathFile": true,
    "markdown-preview-enhanced.enablePreviewZenMode": false,
    "markdown-preview-enhanced.hideDefaultVSCodeMarkdownPreviewButtons": false,
    "markdown-preview-enhanced.imageFolderPath": "./assets",
    "markdown-preview-enhanced.mermaidTheme": "dark",
    "markdown-preview-enhanced.previewTheme": "solarized-dark.css",
    "markdown-preview-enhanced.scrollSync": false,
    "markdown.copyFiles.destination": {
        "*": "md_images/${documentBaseName}/"
    },
    "markdown.marp.exportType": "pptx",
    "markdown.marp.html": "default",
    "markdown.marp.pptx.editable": "on",
    "markdown.marp.themes": [
        "https://rainbowflesh.github.io/css/rose-pine-dawn.css",
        "https://rainbowflesh.github.io/css/rose-pine-moon.css",
        "https://rainbowflesh.github.io/css/rose-pine.css"
    ],
    "markdownlint.config": {
        "default": true,
        "MD007": {
            "indent": 4 // リストのインデントをスペース4つに設定
        },
        "MD024": false, // 同一レベルの見出しの重複を許可
        "MD029": {
            "style": "one" // すべてのリスト番号を "1." に強制する設定
        },
        "MD033": false, // HTML タグの使用を許可
        "MD034": false, // 不要なエスケープ文字の使用を許可
        "MD036": false, // 複数の連続する空行を許可
        "MD041": false, // ファイルの最初の行が見出しであることを要求するルールを無効化 (フロントマター対策)
        "MD047": false, // ファイルの最後に改行を要求するルールを無効化 (markdown-pdf でエクスポートした際に余分な改行が入るのを防止)
        "MD048": false // ファイルの最初に改行を要求するルールを無効化 (フロントマター対策)
    },
    "oxc.enable.oxfmt": true,
    "oxc.enable.oxlint": true,
    "oxc.path.oxfmt": "/Users/fujisawakoki/Library/pnpm/oxfmt", // pnpm で oxfmt をグローバルインストールしている前提 (pnpm install -g oxfmt)
    "oxc.path.oxlint": "/Users/fujisawakoki/Library/pnpm/oxlint", // pnpm で oxlint をグローバルインストールしている前提 (pnpm install -g oxlint)
    "Prettier-SQL.expressionWidth": 120,
    "Prettier-SQL.keywordCase": "upper",
    "Prettier-SQL.SQLFlavourOverride": "postgresql",
    "search.useGlobalIgnoreFiles": true,
    "security.workspace.trust.untrustedFiles": "open",
    "stylelint.packageManager": "pnpm",
    "stylelint.validate": [
        "css",
        "astro"
    ],
    "svg.preview.mode": "svg",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.profiles.osx": {
        "bash": {
            "args": [
                "-l"
            ],
            "icon": "terminal-bash",
            "path": "bash"
        },
        "fish": {
            "args": [
                "-l"
            ],
            "path": "/opt/homebrew/bin/fish"
        },
        "pwsh": {
            "icon": "terminal-powershell",
            "path": "pwsh"
        },
        "tmux": {
            "icon": "terminal-tmux",
            "path": "tmux"
        },
        "zsh": {
            "args": [
                "-l"
            ],
            "path": "zsh"
        }
    },
    "terminal.integrated.scrollback": 50000,
    "terminal.integrated.sendKeybindingsToShell": false, // true にすると fish でペーストできない問題が発生する
    "terminal.integrated.tabs.enabled": true,
    "todohighlight.keywords": [
        {
            "backgroundColor": "#ff4500",
            "color": "#fff",
            "text": "TODO"
        },
        {
            "backgroundColor": "#006400",
            "color": "#fff",
