{
  // =========================================
  "Table": {
    "prefix": "table",
    "body": [
      "| $1 | $2 |",
      "|:-:|:-:|",
      "| $3 | $4 |",
    ],
  },
  // =========================================mermaid
  "mermaid flowchart": {
    "prefix": "mermaid flowchart",
    "body": [
      "- その他の書き方は下記参照",
      "  - https://mermaid-js.github.io/mermaid/#/flowchart",
      "```mermaid",
      "flowchart TB",
      "  node1[node 1 text]",
      "  node2(node 2 text)",
      "  node3((node 3 text))",
      "  node4>node 4 text]",
      "  node5{if処理}",
      "",
      "  subgraph subgraph 1",
      "    node1 --> node2",
      "    node2 --test--> node3",
      "  end",
      "  node3 -.-> node4",
      "  node4 -.test.-> node5",
      "",
      "",
      "  node1 --- node5",
      "  node5 ==> node1",
      "",
      "",
      "  database[(datebase 1)]",
      "  subroutine[[定義済み処理]]",
      "  in/out[/入出力/]",
      "  S[/ループ始点\\]",
      "  E[\\ループ終点/]",
      "  S --- E",
      "  node6([start/end])",
      "  node7{{準備}}",
      "```"
    ]
  },
  "mermaid sequenceDiagram": {
    "prefix": "mermaid sequenceDiagram",
    "body": [
      "- その他の書き方は下記参照",
      "  - https://mermaid-js.github.io/mermaid/#/sequenceDiagram",
      "```mermaid",
      "sequenceDiagram",
      "  participant cook as シェフ",
      "  participant kitchenware1 as 鍋",
      "",
      "  cook ->>+ kitchenware1: 材料の投入",
      "  Note right of kitchenware1: 材料の詳細は別資料参照",
      "  Note over cook, kitchenware1: 5分程待つ",
      "  kitchenware1 -->>- cook: 材料が煮える",
      "",
      "  alt ビーフカレー",
      "    cook ->> kitchenware1:牛肉を入れる",
      "  else チキンカレー",
      "    cook ->> kitchenware1:鶏肉を入れる",
      "  end",
      "",
      "  opt 辛いもの好き",
      "    cook ->> kitchenware1: チリペッパーを入れる",
      "  end",
      "",
      "  rect rgba(255, 0, 255, 0.2)",
      "    loop ときどき",
      "      cook ->> kitchenware1: 混ぜる",
      "    end",
      "  end",
      "```"
    ]
  },
  "mermaid classDiagram": {
    "prefix": "mermaid classDiagram",
    "body": [
      "- その他の書き方は下記参照",
      "  - https://mermaid-js.github.io/mermaid/#/sequenceDiagram",
      "",
      "- 可視性、抽象、静的",
      "  - \\+ Public",
      "  - \\- Private",
      "  - \\# Protected",
      "  - \\~ Package/Internal",
      "  - \\* Abstract e.g.: someAbstractMethod()*",
      "  - \\$ Static e.g.: someStaticMethod()$",
      "",
      "- 数",
      "  - 1 ===> Only 1",
      "  - 0..1 ===> Zero or One",
      "  - 1..* ===> One or more",
      "  - \\* ===> Many",
      "  - n n ===> {where n>1}",
      "  - 0..n ===> zero to n {where n>1}",
      "  - 1..n ===> one to n {where n>1}",
      "",
      "- アノテーション",
      "  - \\<\\<Interface>> To represent an Interface class",
      "  - \\<\\<Abstract>> To represent an abstract class",
      "  - \\<\\<Service>> To represent a service class",
      "  - \\<\\<Enumeration>> To represent an enum",
      "",
      "```mermaid",
      "classDiagram",
      "  %% 向きを変える",
      "  direction LR",
      "",
      "  class Square~Shape~{",
      "    int id",
      "    List~int~ position",
      "    setPoints(List~int~ points)",
      "    getPoints() List~int~",
      "  }",
      "",
      "  Square : -List~string~ messages",
      "  Square : +setMessages(List~string~ messages)",
      "  Square : +getMessages() List~string~",
      "",
      "  classA --|> classB : Inheritance",
      "  classC --* classD : Composition",
      "  classE --o classF : Aggregation",
      "  classG --> classH : Association",
      "  classI -- classJ : Link(Solid)",
      "  classK ..> classL : Dependency",
      "  classM ..|> classN : Realization",
      "  classO .. classP : Link(Dashed)",
      "",
      "  Customer \"1\" --> \"*\" Ticket",
      "  Student \"1\" --> \"1..*\" Course",
      "  Galaxy --> \"many\" Star : Contains",
      "",
      "  class Shape",
      "  <<interface>> Shape",
      "  Shape : noOfVertices",
      "  Shape : draw()",
      "```"
    ]
  },
  "mermaid ganttDiagram": {
    "prefix": "mermaid ganttDiagram",
    "body": [
      "- その他の書き方は下記参照",
      "  - https://mermaid-js.github.io/mermaid/#/flowchart",
      "```mermaid",
      "gantt ",
      "  dateFormat HH:mm",
      "  axisFormat %H:%M",
      "",
      "  自宅: milestone, m1, 10:00, 2min",
      "  成田空港に移動 : 12:00, 120min",
      "  成田空港 → 福岡空港 : 15:00, 17:30",
      "  福岡空港 → 宿へ移動 : 60min",
      "  荷物取りに行く: 30min",
      "  荷物を置いて軽く観光〜夕飯 : 60min",
      "```"
    ]
  },
  "mermaid DB(ER)": {
    "prefix": "mermaid DB-ER",
    "body": [
      "- その他の書き方は下記参照",
      "  - https://mermaid-js.github.io/mermaid/#/sequenceDiagram",
      "",
      "```mermaid",
      "erDiagram",
      "  $1",
      "```",
      "# Sample",
      "",
      "```mermaid",
      "erDiagram",
      "    CUSTOMER ||--o{ ORDER : places",
      "    ORDER ||--|{ LINE-ITEM : contains",
      "    CUSTOMER }|..|{ DELIVERY-ADDRESS : uses",
      "```",
      "",
      "```mermaid",
      "erDiagram",
      "    CUSTOMER ||--o{ ORDER : places",
      "    CUSTOMER {",
      "        string name",
      "        string custNumber",
      "        string sector",
      "    }",
      "    ORDER ||--|{ LINE-ITEM : contains",
      "    ORDER {",
      "        int orderNumber",
      "        string deliveryAddress",
      "    }",
      "    LINE-ITEM {",
      "        string productCode",
      "        int quantity",
      "        float pricePerUnit",
      "    }",
      "```",
      "",
      "```mermaid",
      "erDiagram",
      "    CAR ||--o{ NAMED-DRIVER : allows",
      "    PERSON ||--o{ NAMED-DRIVER : is",
      "```",
      "```mermaid",
      "erDiagram",
      "    CAR ||--o{ NAMED-DRIVER : allows",
      "    CAR {",
      "        string registrationNumber",
      "        string make",
      "        string model",
      "    }",
      "    PERSON ||--o{ NAMED-DRIVER : is",
      "    PERSON {",
      "        string firstName",
      "        string lastName",
      "        int age",
      "    }",
      "```",
      "```mermaid",
      "erDiagram",
      "    CAR ||--o{ NAMED-DRIVER : allows",
      "    CAR {",
      "        string registrationNumber",
      "        string make",
      "        string model",
      "    }",
      "    PERSON ||--o{ NAMED-DRIVER : is",
      "    PERSON {",
      "        string firstName",
      "        string lastName",
      "        int age",
      "    }",
      "```",
      "```mermaid",
      "erDiagram",
      "    CAR ||--o{ NAMED-DRIVER : allows",
      "    CAR {",
      "        string allowedDriver FK \"The license of the allowed driver\"",
      "        string registrationNumber",
      "        string make",
      "        string model",
      "    }",
      "    PERSON ||--o{ NAMED-DRIVER : is",
      "    PERSON {",
      "        string driversLicense PK \"The license #\"",
      "        string firstName",
      "        string lastName",
      "        int age",
      "    }",
      "```"
    ]
  },
  // =========================================PlantUML
  "#PlantUML-AWS": {
    "prefix": "plantuml-aws",
    "body": [
      "```plantuml",
      "@startuml $1",
      "",
      "title $2",
      "left to right direction",
      "",
      "'===============================",
      "' definition & import",
      "'===============================",
      "!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v11.1/dist",
      "",
      "!includeurl AWSPuml/AWSCommon.puml",
      "",
      "!includeurl AWSPuml/General/Client.puml",
      "!includeurl AWSPuml/GroupIcons/Cloudalt.puml",
      "!includeurl AWSPuml/ApplicationIntegration/APIGateway.puml",
      "!includeurl AWSPuml/Compute/Lambda.puml",
      "!includeurl AWSPuml/Database/DynamoDB.puml",
      "",
      "!includeurl AWSPuml/AWSSimplified.puml",
      "",
      "'===============================",
      "' declaration",
      "'===============================",
      "Client(clientUser, User, User client device)",
      "",
      "Cloudalt(aws, AWS, AWS) {",
      "  APIGateway(apiGateway, \"API Gateway\", \"API Gateway\")",
      "  Lambda(lambda, \"Lambda\", \"Lambda\")",
      "  DynamoDB(dynamodb, \"DynamoDB\", \"DynamoDB\")",
      "}",
      "",
      "'===============================",
      "' relationship",
      "'===============================",
      "clientUser 0--> apiGateway: Send HTTPS request",
      "apiGateway 0--> lambda: Invoke function",
      "lambda 0--> dynamodb: Put item",
      "",
      "@enduml",
      "```"
    ]
  },
}