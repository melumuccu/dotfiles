{{- $editor := "code" -}}
{{- if eq .chezmoi.os "windows" -}}
    {{- $editor = "code.cmd" -}}
{{- end -}}

[edit]
    command = {{ $editor | quote }}
    args = [
        "--wait", 
        "--merge", 
        '{{ "{{ .Destination }}" }}', 
        '{{ "{{ .Target }}" }}', 
        '{{ "{{ .Source }}" }}', 
        '{{ "{{ .Source }}" }}'
    ]
    apply = true

[git]
    autoCommit = true

[bitwarden]
    unlock = "auto"
