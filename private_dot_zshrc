# ffmpegによる変換
## .mov => .gif($1: 対象ファイルの絶対パス)
movtogif() {
  filepath="$1" # ファイルパス
  dirpath=$(dirname ${filepath}) # パス部
  fileNameExcludeExtension=$(basename ${filepath} .mov) # 拡張子を削除したファイル名
  if [ ! -d ${dirpath}/output ]; then
    mkdir ${dirpath}/output
  fi
  outputFile=${dirpath}/output/${fileNameExcludeExtension}.gif
  ffmpeg -i ${filepath} -r 12 ${outputFile}
  open -a /Applications/Google\ Chrome.app ${outputFile}
}



