# Image

## .webp に変換
function convertWebp() {
    if [ "$#" -ne 1 ]; then
        echo "使い方: webp <path_to_file>"
        return 1
    fi

    INPUT="$1"

    # ディレクトリかどうかをチェック
    if [ -d "$INPUT" ]; then
        # ディレクトリの中身を探索し、画像ファイルをwebp変換
        find "$INPUT" -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.gif" \) -exec bash -c '
            for FILE; do
                DIRNAME=$(dirname "$FILE")
                BASENAME=$(basename "$FILE")
                FILENAME="${BASENAME%.*}"
                OUTPUT="$DIRNAME/$FILENAME.webp"

                # すでにwebpかどうかチェック
                if [ "${FILE##*.}" = "webp" ]; then
                    echo "$FILE は既にwebp形式です。"
                else
                    # webpに変換
                    cwebp "$FILE" -o "$OUTPUT"

                    # 変換成功チェック
                    if [ $? -eq 0 ]; then
                        rm "$FILE"
                        echo "$FILE をwebpに変換しました。"
                    else
                        echo "$FILE のwebp変換に失敗しました。"
                    fi
                fi
            done
        ' _ {} +
    else
        # 単一のファイルを処理
        DIRNAME=$(dirname "$INPUT")
        BASENAME=$(basename "$INPUT")
        FILENAME="${BASENAME%.*}"
        EXTENSION="${BASENAME##*.}"

        if [ -z "$EXTENSION" ]; then
            echo "ファイルの拡張子が特定できませんでした。"
            return 1
        fi

        # すでにwebpかどうかチェック
        if [ "$EXTENSION" = "webp" ]; then
            echo "$INPUT は既にwebp形式です。"
            return 1
        fi

        OUTPUT="$DIRNAME/$FILENAME.webp"

        # webpに変換
        cwebp "$INPUT" -o "$OUTPUT"

        # 変換成功チェック
        if [ $? -eq 0 ]; then
            rm "$INPUT"
            echo "$INPUT をwebpに変換しました。"
        else
            echo "$INPUT のwebp変換に失敗しました。"
            return 1
        fi
    fi
}

alias cw='convertWebp'






## .heic を .jpeg に変換
function convertHeicToJpeg() {
    if [ "$#" -ne 1 ]; then
        echo "Usage: heictojpeg <path_to_file>"
        return 1
    fi

    INPUT_FILE="$1"
    DIRNAME=$(dirname "$INPUT_FILE")
    BASENAME=$(basename "$INPUT_FILE")
    FILENAME=$(echo "$BASENAME" | awk -F. '{print $1}')
    EXTENSION=$(echo "$BASENAME" | awk -F. '{if (NF>1) {print tolower($NF)}}')

    if [ "$EXTENSION" != "heic" ]; then
        echo "The file is not a HEIC format."
        return 1
    fi

    OUTPUT_FILE="$DIRNAME/$FILENAME.jpeg"

    # Convert to jpeg format
    magick convert "$INPUT_FILE" "$OUTPUT_FILE"

    # Check if conversion was successful
    if [ $? -eq 0 ]; then
        echo "$INPUT_FILE has been converted to"
	  echo "$OUTPUT_FILE"
    else
        echo "Failed to convert $INPUT_FILE to jpeg."
        return 1
    fi
}

alias ch='convertHeicToJpeg'



## 画像のw, hを変換
function WidthHeightConvert() {
    if [ "$#" -lt 2 ]; then
        echo "Usage: wh <path_to_image> <width> [height]"
        return 1
    fi

    INPUT_FILE="$1"
    WIDTH="$2"

    # 第三引数としてheightが提供されたかチェック
    if [ -n "$3" ]; then
        # heightが提供された場合、強制的に比率を変更
        HEIGHT="$3"
        convert "$INPUT_FILE" -resize "${WIDTH}x${HEIGHT}!" "$INPUT_FILE"
    else
        # heightが提供されなかった場合、比率を維持
        # 元の画像のアスペクト比を取得
        ASPECT_RATIO=$(identify -format "%[fx:h/w]" "$INPUT_FILE")
        # 新しい高さを計算
        HEIGHT=$(echo "$WIDTH * $ASPECT_RATIO" | bc)
        # 小数点以下を切り捨てて整数に
        HEIGHT=${HEIGHT%.*}
        convert "$INPUT_FILE" -resize "${WIDTH}x${HEIGHT}" "$INPUT_FILE"
    fi

    if [ $? -ne 0 ]; then
        echo "Failed to resize $INPUT_FILE."
        return 1
    fi
}

alias wh='WidthHeightConvert'



