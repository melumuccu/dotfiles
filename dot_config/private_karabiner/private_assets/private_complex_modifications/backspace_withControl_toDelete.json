{
  "title": "Control + Backspace to Delete",
  "rules": [
    {
      "description": "Change Control + Backspace to Delete",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": ["left_control"]
            }
          },
          "to": [
            {
              "key_code": "forward_delete"
            }
          ]
        }
      ]
    }
  ]
}